# ============================================================
#  Telegram Channel Parser Bot — конфигурация
# ============================================================

# 1. Получи на https://my.telegram.org → "API development tools"
API_ID=
API_HASH=

# 2. Получи у @BotFather командой /newbot
BOT_TOKEN=

# 3. Папка для сохранения JSON-файлов (создаётся автоматически)
OUTPUT_DIR=output
